{
  "version": 2,
  "builds": [
    { "src": "html/*.html", "use": "@vercel/static" },
    { "src": "images/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/html/index.html" },
    { "src": "/index.html", "dest": "/html/index.html" },
    { "src": "/landing.html", "dest": "/html/landing.html" },
    { "src": "/login.html", "dest": "/html/login.html" },
    { "src": "/brand-dashboard.html", "dest": "/html/brand-dashboard.html" },
    { "src": "/supplier-dashboard.html", "dest": "/html/supplier-dashboard.html" },
    { "src": "/community.html", "dest": "/html/community.html" },
    { "src": "/new-order.html", "dest": "/html/new-order.html" },
    { "src": "/order-list.html", "dest": "/html/order-list.html" },
    { "src": "/order-detail.html", "dest": "/html/order-detail.html" },
    { "src": "/settlement.html", "dest": "/html/settlement.html" },
    { "src": "/images/(.*)", "dest": "/images/$1" }
  ]
}
